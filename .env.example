# 秃秃IP内容生成系统 — 环境变量配置
# 复制此文件为 .env 并填入真实密钥
# cp .env.example .env

# === 豆包/火山引擎 (Seedance视频 + ARK大模型) ===
ARK_API_KEY=your_ark_api_key_here

# === Gemini API ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_URL=https://ai.ssnai.com/gemini/v1beta/models/gemini-2.0-flash:generateContent

# === LLM提供商选择: gemini / claude / ark / openai ===
LLM_PROVIDER=gemini

# === Claude API (可选，使用claude时需要) ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === OpenAI API (可选，使用openai时需要) ===
OPENAI_API_KEY=your_openai_api_key_here

# === Admin API密钥 (保护管理接口) ===
ADMIN_API_KEY=change_me_to_a_random_string
